---
interface Props {
    title: string;
    active: 'bookings' | 'suppliers' | 'tours' | 'sites' | 'calendar' | 'analytics' | 'agents';
}
const { title, active } = Astro.props;
const userEmail = Astro.locals.userEmail;

const nav = [
    { label: 'Bookings',  href: '/bookings',  key: 'bookings'  },
    { label: 'Calendar',  href: '/calendar',  key: 'calendar'  },
    { label: 'Analytics', href: '/analytics', key: 'analytics' },
    { label: 'Suppliers', href: '/suppliers', key: 'suppliers' },
    { label: 'Tours',     href: '/tours',     key: 'tours'     },
    { label: 'Sites',     href: '/sites',     key: 'sites'     },
    { label: 'Agents',    href: '/agents',    key: 'agents'    },
] as const;
---

<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-100">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — FireCow Admin</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🐄</text></svg>" />
</head>
<body class="h-full flex">

    <!-- Sidebar -->
    <aside class="w-56 flex-shrink-0 bg-gray-950 flex flex-col">
        <div class="px-5 py-5 border-b border-gray-800">
            <span class="text-white font-bold text-lg tracking-tight">🐄 FireCow Admin</span>
        </div>
        <nav class="flex-1 px-3 py-4 space-y-1">
            {nav.map(({ label, href, key }) => (
                <a
                    href={href}
                    class={`flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
                        active === key
                            ? 'bg-blue-600 text-white'
                            : 'text-gray-400 hover:bg-gray-800 hover:text-white'
                    }`}
                >
                    {label}
                </a>
            ))}
        </nav>
        <div class="px-5 py-4 border-t border-gray-800">
            <p class="text-gray-500 text-xs truncate">{userEmail}</p>
        </div>
    </aside>

    <!-- Main -->
    <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
        <header class="bg-white border-b border-gray-200 px-8 py-4 flex items-center justify-between flex-shrink-0">
            <h1 class="text-xl font-semibold text-gray-900">{title}</h1>
        </header>
        <main class="flex-1 overflow-auto p-8">
            <slot />
        </main>
    </div>

</body>
</html>

<style is:global>
    @tailwind base;
    @tailwind components;
    @tailwind utilities;

    html, body { height: 100%; }
</style>
