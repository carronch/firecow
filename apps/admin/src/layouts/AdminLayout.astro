---
import SeasonAlert from '../components/SeasonAlert';

interface Props {
    title: string;
    active: 'bookings' | 'suppliers' | 'tours' | 'sites' | 'calendar' | 'analytics' | 'agents' | 'reviewers';
}
const { title, active } = Astro.props;
const userEmail = Astro.locals.userEmail;

const nav = [
    { label: 'Bookings',  href: '/bookings',  key: 'bookings'  },
    { label: 'Calendar',  href: '/calendar',  key: 'calendar'  },
    { label: 'Analytics', href: '/analytics', key: 'analytics' },
    { label: 'Suppliers', href: '/suppliers', key: 'suppliers' },
    { label: 'Tours',     href: '/tours',     key: 'tours'     },
    { label: 'Sites',     href: '/sites',     key: 'sites'     },
    { label: 'Agents',    href: '/agents',    key: 'agents'    },
    { label: 'Review Pool', href: '/reviewers', key: 'reviewers' },
] as const;
---

<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-950 text-slate-200 font-outfit selection:bg-sky-500/30">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — FireCow Admin</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🐄</text></svg>" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="h-full flex overflow-hidden">
    <!-- Background Glows -->
    <div class="fixed top-0 left-1/4 w-[500px] h-[500px] bg-sky-500/10 rounded-full blur-[120px] pointer-events-none z-0"></div>
    <div class="fixed bottom-0 right-1/4 w-[500px] h-[500px] bg-purple-500/10 rounded-full blur-[120px] pointer-events-none z-0"></div>

    <!-- Sidebar -->
    <aside class="w-64 flex-shrink-0 bg-slate-900/40 backdrop-blur-xl border-r border-slate-800 flex flex-col z-10">
        <div class="px-6 py-6 border-b border-slate-800/60">
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-400 to-purple-400 font-extrabold text-xl tracking-tight">🐄 FireCow Admin</span>
        </div>
        <nav class="flex-1 px-4 py-6 space-y-2">
            {nav.map(({ label, href, key }) => (
                <a
                    href={href}
                    class={`flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 ${
                        active === key
                            ? 'bg-gradient-to-r from-sky-500 to-purple-600 text-white shadow-[0_0_20px_rgba(168,85,247,0.4)]'
                            : 'text-slate-400 hover:bg-slate-800/50 hover:text-white'
                    }`}
                >
                    {label}
                </a>
            ))}
        </nav>
        <div class="px-6 py-5 border-t border-slate-800/60 bg-slate-950/20">
            <p class="text-slate-500 text-xs truncate font-medium">{userEmail}</p>
        </div>
    </aside>

    <!-- Main -->
    <div class="flex-1 flex flex-col min-w-0 z-10 relative">
        <header class="bg-slate-900/40 backdrop-blur-xl border-b border-slate-800/60 flex-shrink-0">
            <div class="px-8 py-5 flex items-center justify-between">
                <h1 class="text-2xl font-bold text-white tracking-tight">{title}</h1>
            </div>
            <SeasonAlert client:load />
        </header>
        <main class="flex-1 overflow-auto p-8 relative">
            <slot />
        </main>
    </div>

</body>
</html>

<style is:global>
    @tailwind base;
    @tailwind components;
    @tailwind utilities;

    html, body { height: 100%; }
    .font-outfit { font-family: 'Outfit', sans-serif; }
</style>
