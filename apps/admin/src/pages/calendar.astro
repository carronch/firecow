---
import AdminLayout from '../layouts/AdminLayout.astro';
import CalendarView from '../components/CalendarView';
import { getBookings, API_BASE, ADMIN_TOKEN, type Booking } from '../lib/api';

export const prerender = false;

let bookings: Booking[] = [];
try { bookings = await getBookings(); } catch {}
---

<AdminLayout title="Calendar" active="calendar">
    <CalendarView
        client:load
        initialBookings={bookings}
        apiBase={API_BASE}
        adminToken={ADMIN_TOKEN}
    />
</AdminLayout>
