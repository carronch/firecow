---
import AdminLayout from '../layouts/AdminLayout.astro';
---

<AdminLayout title="Architecture Pitch" active="pitch">
    <div class="h-[82vh] w-full rounded-xl overflow-hidden shadow-2xl border border-slate-700/50 bg-slate-900/50 relative">
        <iframe src="/pitch.html" class="w-full h-full border-0 overflow-y-auto mix-blend-lighten" title="Pitch Deck"></iframe>
        
        <div class="absolute top-4 right-4 pointer-events-none">
            <span class="bg-indigo-500/20 text-indigo-300 px-3 py-1.5 rounded-full text-xs font-bold border border-indigo-500/30 backdrop-blur">
                LIVE PREVIEW
            </span>
        </div>
    </div>
</AdminLayout>
