---
import AdminLayout from '../layouts/AdminLayout.astro';
import SitesTable from '../components/SitesTable';
import { getSites, getSuppliers, API_BASE, ADMIN_TOKEN, type Site, type Supplier } from '../lib/api';

export const prerender = false;

let sites: Site[] = [];
let suppliers: Supplier[] = [];
try { [sites, suppliers] = await Promise.all([getSites(), getSuppliers()]); } catch {}
---

<AdminLayout title="Sites" active="sites">
    <SitesTable
        client:load
        initialSites={sites}
        suppliers={suppliers}
        apiBase={API_BASE}
        adminToken={ADMIN_TOKEN}
    />
</AdminLayout>
