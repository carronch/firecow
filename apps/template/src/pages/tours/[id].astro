---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getTourById } from '../../utils/zoho';

export const prerender = false;

const { id } = Astro.params;
const env = Astro.locals?.runtime?.env || import.meta.env;
const tour = id ? await getTourById(id, env) : null;

// If tour not found, redirect to home or show 404
if (!tour) {
  return Astro.redirect('/404');
}

const pageTitle = `${tour.name} - FireCow Bookings`;
---

<BaseLayout title={pageTitle}>
  <Header />

  <main class="min-h-screen bg-white">
    <!-- Hero Banner -->
    <div class="relative h-[60vh] min-h-[500px]">
      <div class="absolute inset-0">
        <img 
          src={tour.image} 
          alt={tour.name} 
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-slate-900/40 to-transparent"></div>
      </div>
      <div class="absolute bottom-0 left-0 w-full p-8 md:p-12">
        <div class="container mx-auto">
          <div class="max-w-4xl">
            <span class="inline-block px-4 py-1 mb-4 text-sm font-bold tracking-wider text-white uppercase bg-blue-600 rounded-full">
              {tour.category || 'Tour'}
            </span>
            <h1 class="text-4xl md:text-6xl font-heading font-extrabold text-white mb-4 drop-shadow-lg">
              {tour.name}
            </h1>
            <div class="flex flex-wrap items-center gap-6 text-white text-lg font-medium">
              <div class="flex items-center gap-2">
                <i class="fa-regular fa-clock" aria-hidden="true"></i>
                <span>{tour.duration}</span>
              </div>
              <div class="flex items-center gap-2">
                <i class="fa-solid fa-tag" aria-hidden="true"></i>
                <span>From ${tour.price}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="container mx-auto px-4 py-16">
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Main Info -->
        <div class="lg:col-span-2">
          <h2 class="text-3xl font-bold font-heading mb-6 text-gray-900">About this Experience</h2>
          <div class="prose prose-lg text-gray-700 max-w-none">
            <p>{tour.description}</p>
          </div>

          <!-- Additional features/expectations can go here -->
          <div class="mt-12 p-8 bg-blue-50 rounded-2xl">
            <h3 class="text-xl font-bold text-blue-900 mb-4">Why choose this tour?</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-blue-800">
                <i class="fa-solid fa-circle-check mt-1" aria-hidden="true"></i>
                <span>Premium experience with expert guides</span>
              </li>
              <li class="flex items-start gap-3 text-blue-800">
                <i class="fa-solid fa-circle-check mt-1" aria-hidden="true"></i>
                <span>Safety first commitment</span>
              </li>
              <li class="flex items-start gap-3 text-blue-800">
                <i class="fa-solid fa-circle-check mt-1" aria-hidden="true"></i>
                <span>Comfortable, modern vessels</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Sidebar CTA -->
        <div class="lg:col-span-1">
          <div class="sticky top-24 bg-white border border-gray-200 rounded-2xl shadow-xl p-8">
            <h3 class="text-2xl font-bold text-gray-900 mb-2">Book Your Spot</h3>
            <p class="text-gray-600 mb-6">Reserve now to secure your availability.</p>
            
            <div class="flex items-baseline gap-1 mb-8">
              <span class="text-sm text-gray-500 font-medium">From</span>
              <span class="text-4xl font-bold text-blue-600">${tour.price}</span>
              <span class="text-gray-500">/ person</span>
            </div>

            <a 
              href="/reservation" 
              class="block w-full text-center bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 px-6 rounded-xl transition-all shadow-lg hover:shadow-blue-500/30 transform hover:-translate-y-1"
            >
              Check Availability
            </a>

            <div class="mt-6 text-center">
              <p class="text-sm text-gray-500 flex items-center justify-center gap-2">
                <i class="fa-solid fa-lock text-green-500" aria-hidden="true"></i>
                Secure Booking
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
