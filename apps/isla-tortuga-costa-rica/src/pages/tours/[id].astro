---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BookingWidget from '../../components/BookingWidget.astro';
import { getEntry } from 'astro:content';

export const prerender = false;

const { id } = Astro.params;
const tourEntry = id ? await getEntry('tours', id) : null;

// If tour not found, redirect to home or show 404
if (!tourEntry) {
  return Astro.redirect('/404');
}

const tour = tourEntry.data;
const pageTitle = `${tour.title} - FireCow Bookings`;

const schema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": tour.title,
  "description": tour.description,
  "url": Astro.url.href,
  "image": tour.heroImage,
  "offers": {
    "@type": "Offer",
    "price": typeof tour.price === 'number' ? tour.price : tour.price.adult,
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock"
  }
};
---

<BaseLayout title={pageTitle} schema={schema}>
  <Header />

  <main class="min-h-screen bg-white">
    <!-- Hero Banner -->
    <div class="relative h-[60vh] min-h-[500px]">
      <div class="absolute inset-0">
        <img 
          src={tour.heroImage} 
          alt={tour.title} 
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-slate-900/40 to-transparent"></div>
      </div>
      <div class="absolute bottom-0 left-0 w-full p-8 md:p-12">
        <div class="container mx-auto">
          <div class="max-w-4xl">
            {tour.featured && (
            <span class="inline-block px-4 py-1 mb-4 text-sm font-bold tracking-wider text-white uppercase bg-blue-600 rounded-full">
              Featured Experience
            </span>
            )}
            <h1 class="text-4xl md:text-6xl font-heading font-extrabold text-white mb-4 drop-shadow-lg">
              {tour.title}
            </h1>
            <div class="flex flex-wrap items-center gap-6 text-white text-lg font-medium">
              <div class="flex items-center gap-2">
                <i class="fa-regular fa-clock" aria-hidden="true"></i>
                <span>{tour.duration}</span>
              </div>
              <div class="flex items-center gap-2">
                <i class="fa-solid fa-tag" aria-hidden="true"></i>
                <span>From ${typeof tour.price === 'number' ? tour.price : tour.price.adult}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="container mx-auto px-4 py-16">
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Main Info -->
        <div class="lg:col-span-2">
          <h2 class="text-3xl font-bold font-heading mb-6 text-gray-900">About this Experience</h2>
          <div class="prose prose-lg text-gray-700 max-w-none">
            <p>{tour.description}</p>
            <!-- Render markdown body if needed, currently we just put basic description. 
                 To render full markdown body: <Content /> (need to use tourEntry.render()) -->
          </div>
          
           <!-- Render Full Body Content -->
           <div class="prose prose-lg text-gray-700 max-w-none mt-8">
             {await tourEntry.render().then(({ Content }) => <Content />)}
           </div>

          <!-- Additional features/expectations can go here -->
          <div class="mt-12 p-8 bg-blue-50 rounded-2xl">
            <h3 class="text-xl font-bold text-blue-900 mb-4">What's Included</h3>
            <ul class="space-y-3">
              {tour.included?.map(item => (
                <li class="flex items-start gap-3 text-blue-800">
                    <i class="fa-solid fa-circle-check mt-1" aria-hidden="true"></i>
                    <span>{item}</span>
                </li>
              ))}
              {!tour.included && (
                  <p class="text-blue-800">Contact us for details.</p>
              )}
            </ul>
          </div>
        </div>

        <!-- Sidebar CTA -->
        <div class="lg:col-span-1">
          <div class="sticky top-24">
             <!-- Use the new BookingWidget with tourId pre-selected -->
             <BookingWidget tourId={tourEntry.slug} className="mt-0" />
             
             <div class="mt-6 text-center">
               <p class="text-sm text-gray-500 flex items-center justify-center gap-2">
                 <i class="fa-solid fa-lock text-green-500" aria-hidden="true"></i>
                 Secure Booking
               </p>
             </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
