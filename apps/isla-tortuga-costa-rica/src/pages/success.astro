---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const prerender = false;
---

<BaseLayout title="Booking Confirmed | Costa Cat Cruises">
  <Header />

  <main class="min-h-[70vh] flex items-center justify-center bg-gray-50 py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-lg mx-auto bg-white rounded-2xl shadow-xl p-8 md:p-12 text-center">
        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <i class="fa-solid fa-check text-4xl text-green-600" aria-hidden="true"></i>
        </div>
        
        <h1 class="text-3xl md:text-4xl font-bold font-heading text-gray-900 mb-4">Booking Confirmed!</h1>
        <p class="text-gray-600 text-lg mb-8 leading-relaxed">
          Thank you for choosing Costa Cat Cruises. We have received your booking and sent a confirmation email to you.
        </p>

        <div class="space-y-4">
          <a href="/" class="block w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-xl transition-all shadow-lg hover:shadow-blue-500/30">
            Return to Home
          </a>
          <a href="#contact" class="block w-full bg-white border border-gray-200 hover:bg-gray-50 text-gray-700 font-bold py-3 px-6 rounded-xl transition-all">
            Contact Support
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
