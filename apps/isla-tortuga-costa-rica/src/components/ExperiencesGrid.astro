---
import Button from './Button.astro';
import OptimizedImage from './common/OptimizedImage.astro';
import { getCollection } from 'astro:content';

// Fetch tours from Content Collection
const toursEntries = await getCollection('tours');
const tours = toursEntries.filter(t => !t.data.draft);
---

<section id="experiences" class="py-20 bg-gray-50" aria-label="Available Tours">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <span class="text-blue-700 font-bold tracking-wide uppercase text-sm">Discover Paradise</span>
      <h2 class="text-4xl md:text-5xl font-bold font-heading mt-2 mb-4 text-gray-900">Unforgettable Experiences</h2>
      <p class="text-gray-700 text-lg max-w-2xl mx-auto">Choose from our curated selection of premium tours designed to create lasting memories.</p>
    </div>


    <div id="experiences-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {tours.map(tour => (
        <div class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-gray-100">
          <div class="relative h-64 overflow-hidden">
             <div class="absolute top-4 left-4 z-10 bg-white/95 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider text-gray-900 shadow-sm">
               {tour.data.featured ? 'Featured' : 'Tour'}
             </div>
             <!-- Using standard img for external URLs, fallback to dummy if needed -->
             <img 
               src={tour.data.heroImage} 
               alt={tour.data.title}
               width="800"
               height="600"
               class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
             />
          </div>
          
          <div class="p-8">
            <div class="flex justify-between items-start mb-4">
              <div>
                <h3 class="text-xl font-bold font-heading text-gray-900 mb-2 group-hover:text-blue-700 transition-colors">{tour.data.title}</h3>
                <div class="flex items-center text-gray-600 text-sm">
                  <i class="fa-regular fa-clock mr-2 text-gray-500" aria-hidden="true"></i>
                  {tour.data.duration}
                </div>
              </div>
            </div>

            <p class="text-gray-700 mb-6 text-sm line-clamp-2 leading-relaxed">{tour.data.description}</p>

            <div class="flex items-center justify-between mt-6 pt-6 border-t border-gray-100">
              <div>
                <span class="text-gray-600 text-sm font-medium">From</span>
                <p class="text-2xl font-bold text-blue-700">
                    ${typeof tour.data.price === 'number' ? tour.data.price : tour.data.price.adult}
                </p>
              </div>
              <Button href={`/tours/${tour.slug}`} aria-label={`View details for ${tour.data.title}`}>
                View Details
              </Button>
            </div>
          </div>
        </div>
      ))}
      
      {tours.length === 0 && (
          <div class="col-span-full text-center py-12">
            <p class="text-gray-500">No tours available at the moment.</p>
          </div>
      )}
    </div>
  </div>
</section>
