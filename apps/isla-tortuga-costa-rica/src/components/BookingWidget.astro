---
import { getCollection } from 'astro:content';

interface Props {
  tourId?: string;
  className?: string;
  bookingUrl?: string; // Legacy prop support
}

const { tourId, className = "" } = Astro.props;

import BookingWidgetReact from './BookingWidget.jsx';



const allTours = await getCollection('tours');
const tours = allTours.filter(t => !t.data.draft);
const locale = Astro.currentLocale || 'en';
---

<div class={className}>
    <BookingWidgetReact 
        client:load 
        tours={tours} 
        initialTourId={tourId} 
        locale={locale}
    />
</div>
