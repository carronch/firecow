---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = true;
---

<BaseLayout title="FireCow Manager">
  <div class="container mx-auto p-8">
    <h1 class="text-4xl font-bold mb-8">FireCow Manager 🤠</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="p-6 border rounded-lg shadow-sm hover:shadow-md transition bg-white">
        <h2 class="text-2xl font-semibold mb-2">Sites & Content</h2>
        <p class="text-gray-600 mb-4">Manage hero images, reviews, and tour details.</p>
        <a href="/content" class="text-blue-600 hover:underline">Manage Content &rarr;</a>
      </div>
      <div class="p-6 border rounded-lg shadow-sm hover:shadow-md transition bg-white">
        <h2 class="text-2xl font-semibold mb-2">Operations</h2>
        <p class="text-gray-600 mb-4">View reservations, track tasks, and create bookings.</p>
        <a href="/ops" class="text-blue-600 hover:underline">Go to Ops Center &rarr;</a>
      </div>
    </div>
  </div>
</BaseLayout>
